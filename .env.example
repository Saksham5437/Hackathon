# ─────────────────────────────────────────────────────────
# Mini NotebookLM — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────
# Choose: "gemini" or "openai"
LLM_PROVIDER=gemini

# ── API Keys ──────────────────────────────────────────────
# Get Gemini key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Get OpenAI key: https://platform.openai.com/api-keys
# Only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# ── Embedding Model ───────────────────────────────────────
# HuggingFace sentence-transformer (runs locally, no API key)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── RAG Settings ──────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_CHUNKS=8

# ── Session Memory ────────────────────────────────────────
MAX_HISTORY=10
LLM_MAX_OUTPUT_TOKENS=3072

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000

# ── YouTube Video Recommendations ────────────────────────────────────────────
# Get a FREE key at: https://console.developers.google.com/
# Steps: Create project → Enable "YouTube Data API v3" → Create API key
# Free quota: 10,000 units/day (1 search costs ~100 units)
YOUTUBE_API_KEY=your-youtube-api-key-here
